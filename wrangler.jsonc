{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "terminal-aignited",
  "compatibility_date": "2026-03-01",
  "main": "./worker/index.ts",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": true
  },
  "vars": {
    "API_BASE_URL": "https://terminal.thedailycatalyst.site",
    "AUTH_REDIRECT_URI": "https://terminal.aignited.id/api/auth/callback"
  },
  "triggers": {
    "crons": [
      "30 23 * * *",
      "40 23 * * *"
    ]
  }
  // Secrets (set via `wrangler secret put`):
  //   API_KEY, DATABASE_URL, AUTH_DATABASE_URL,
  //   WORKOS_CLIENT_ID, WORKOS_API_KEY, JWT_SIGNING_SECRET,
  //   MINIMAX_API_KEY, KIMI_API_KEY, OPENROUTER_API_KEY,
  //   MAYAR_API_KEY, MAYAR_WEBHOOK_TOKEN
}
