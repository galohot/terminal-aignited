{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "terminal-aignited",
  "compatibility_date": "2026-03-01",
  "main": "./worker/index.ts",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "vars": {
    "API_BASE_URL": "https://terminal.thedailycatalyst.site"
  }
  // API_KEY and DATABASE_URL go in CF dashboard env vars (encrypted)
}
